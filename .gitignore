# Build outputs
bin/

# Compiler intermediates emitted alongside .Mod sources
*.o
*.ll
*.smb
*.deps

# Test artifacts (BufferTest writes save/load round-trip files)
*.tmp

# Editor's default Save target when no filename is set
untitled.txt

# Editor / OS noise
*~
.DS_Store

# iOS scaffold — .xcodeproj is regenerated by xcodegen from
# ios/project.yml. SPM artifacts and Xcode-derived data are
# transient.
ios/Oed.xcodeproj/
ios/.build/
ios/.swiftpm/
ios/Package.resolved
ios/build/

# Local agent / IDE state
.claude/
.vscode/
.idea/
